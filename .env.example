# Copy to .env and fill in values. Never commit real secrets.

ANTHROPIC_API_KEY=
AGENT_FIXTURE_MODE=true
AGENT_TIMEOUT_SECONDS=300
AGENT_PERMISSION_MODE=bypassPermissions
AGENT_MAX_TURNS=25

# Storage: local (default) or s3
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=ap-south-1
AWS_S3_KEY_PREFIX=workspaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
