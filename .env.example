# Copy to .env and fill in values. Never commit real secrets.

AGENT_FIXTURE_MODE=true
AGENT_TIMEOUT_SECONDS=300
AGENT_PERMISSION_MODE=bypassPermissions
AGENT_MAX_TURNS=25

# Agent LLM provider:
#   anthropic — Claude API (ANTHROPIC_API_KEY)
#   mantle    — Amazon Bedrock Mantle (matches Bedrock console "App integration")
#   bedrock   — classic Amazon Bedrock InvokeModel
AGENT_PROVIDER=mantle
AGENT_MODEL=sonnet

# Required when AGENT_PROVIDER=anthropic and AGENT_FIXTURE_MODE=false
# ANTHROPIC_API_KEY=sk-ant-...

# --- Bedrock Mantle (from Bedrock console → Projects → App integration) ---
# AGENT_PROVIDER=mantle
# ANTHROPIC_WORKSPACE_ID=proj_xxxxxxxx
# AWS_REGION=us-east-1
# ANTHROPIC_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/anthropic
# Bedrock project API key from console (starts with bedrock-api-key-):
# ANTHROPIC_API_KEY=bedrock-api-key-...
# Or use IAM SigV4 instead of API key (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)

# Storage: local (default), cloud (fake S3 on disk), or s3 (AWS)
STORAGE_BACKEND=local

# Max workspaces kept in workspaces_data/ agent cache (cloud/s3 modes)
WORKSPACE_AGENT_CACHE_MAX_SIZE=10

# Required when STORAGE_BACKEND=s3
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1
AWS_S3_KEY_PREFIX=workspaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
